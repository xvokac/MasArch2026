# Project: hinge
# Makefile created by Dev-C++ 4.9.8.0

CPP  = g++.exe
CC   = gcc.exe
WINDRES = windres.exe
RES  = 
OBJ  = main.o $(RES)
LINKOBJ  = main.o $(RES)
LIBS =  -L"C:/DevCpp/lib" 
INCS =  -I"C:/DevCpp/include" 
CXXINCS =  -I"C:/DevCpp/include/c++"  -I"C:/DevCpp/include/c++/mingw32"  -I"C:/DevCpp/include/c++/backward"  -I"C:/DevCpp/include" 
BIN  = hinge.exe
CXXFLAGS = $(CXXINCS) 
CFLAGS = $(INCS) 

.PHONY: all all-before all-after clean clean-custom

all: all-before hinge.exe all-after


clean: clean-custom
	rm -f $(OBJ) $(BIN)

$(BIN): $(LINKOBJ)
	$(CPP) $(LINKOBJ) -o "hinge.exe" $(LIBS)

main.o: main.cpp
	$(CPP) -c main.cpp -o main.o $(CXXFLAGS)
